# Install: sudo cp socmap.service /etc/systemd/system/ && \
#          sudo systemctl daemon-reload && sudo systemctl enable --now socmap
[Unit]
Description=Standalone Norse-style attack map (live threat feeds)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=socmap
WorkingDirectory=/opt/socmap
EnvironmentFile=/opt/socmap/.env
ExecStart=/usr/bin/python3 /opt/socmap/app.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
